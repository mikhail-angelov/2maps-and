<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MapFragment">

    <org.maplibre.android.maps.MapView
        android:id="@+id/mapViewInFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/mainMenuButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="Main Menu"
        android:src="@drawable/ic_menu_vector"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <!-- Group: Bottom-aligned UI elements -->

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCenterOnLocationInFragment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Center on current location"
        android:src="@drawable/ic_navigation"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

    <!-- Radial menu option: Follow only (above main FAB) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRadialFollow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Follow my location"
        android:src="@drawable/ic_navigation"
        android:visibility="gone"
        app:fabSize="mini"
        app:backgroundTint="#4CAF50"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/fabCenterOnLocationInFragment"
        app:layout_constraintEnd_toEndOf="@+id/fabCenterOnLocationInFragment"
        app:layout_constraintStart_toStartOf="@+id/fabCenterOnLocationInFragment"
        tools:visibility="visible" />

    <!-- Radial menu option: Record only (left of main FAB) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRadialRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Record track"
        android:src="@drawable/ic_record"
        android:visibility="gone"
        app:fabSize="mini"
        app:backgroundTint="#E53935"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@+id/fabCenterOnLocationInFragment"
        app:layout_constraintBottom_toBottomOf="@+id/fabCenterOnLocationInFragment"
        tools:visibility="visible" />

    <!-- Radial menu option: Follow + Record (diagonally top-left of main FAB) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRadialFollowRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Follow and record track"
        android:src="@drawable/ic_navigation"
        android:visibility="gone"
        app:fabSize="mini"
        app:backgroundTint="#9C27B0"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toTopOf="@+id/fabCenterOnLocationInFragment"
        app:layout_constraintEnd_toStartOf="@+id/fabCenterOnLocationInFragment"
        tools:visibility="visible" />

    <!-- Gas layer toggle button (positioned relative to the recording radial buttons area) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabToggleGasLayer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Toggle Gas Layer"
        android:src="@drawable/ic_local_gas_station"
        android:visibility="gone"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@+id/fabCenterOnLocationInFragment"
        app:layout_constraintBottom_toBottomOf="@+id/fabCenterOnLocationInFragment"
        tools:ignore="HardcodedText"
        tools:visibility="visible" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabHideTrack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Hide current track"
        android:src="@drawable/ic_timeline_off"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/fabToggleGasLayer"
        app:layout_constraintEnd_toStartOf="@+id/fabToggleGasLayer"
        app:layout_constraintTop_toTopOf="@+id/fabToggleGasLayer"
        tools:ignore="HardcodedText"
        tools:visibility="visible" />


</androidx.constraintlayout.widget.ConstraintLayout>
